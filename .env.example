# Copy to .env and fill in real values. Never commit .env.
# Generate secrets: openssl rand -hex 32

PORT=3000
SKILL_LIBRARY_DATA_DIR=/data

# Optional. Omit to use the bundled PGlite database under /data/db.
# The database engine is selected from the connection-string scheme:
#   postgres:// or postgresql://  → external PostgreSQL
#   sqlserver://                  → Azure SQL Server (Microsoft SQL Server / T-SQL)
# DATABASE_URL=postgres://user:password@postgres.example.com:5432/skill_library
#
# Azure SQL Server: encryption is on by default (Azure requires it). The database
# name is the URL path; credentials go in the userinfo. For a local container with a
# self-signed cert add ?trustServerCertificate=true; to disable TLS use ?encrypt=false.
# DATABASE_URL=sqlserver://user:password@your-server.database.windows.net:1433/skill_library

# CLI/MCP bearer tokens. Generate unique tokens in production.
# Format: token:role:actor-id,token:role:actor-id
SKILL_LIBRARY_API_KEYS=change-me-maintainer:maintainer:maintainer-1,change-me-user:user:user-1

# Required. Session signing secret.
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-32

# Required. Public URL of the registry (no trailing slash). Must match browser URL for SSO.
BETTER_AUTH_URL=http://localhost:3000
# Optional comma-separated extra origins allowed for OAuth callbacks (e.g. Azure default FQDN during DNS cutover).
# BETTER_AUTH_TRUSTED_ORIGINS=https://ca-skill-library.example.azurecontainerapps.io

# Microsoft Entra ID — required for browser "Sign in with Microsoft".
# Azure Portal → App registrations → redirect URI:
#   ${BETTER_AUTH_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=your-azure-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_TENANT_ID=your-azure-tenant-id
