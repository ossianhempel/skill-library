PORT=3000
SKILL_LIBRARY_DATA_DIR=/data

# Optional. If omitted, the app uses bundled PGlite under /data/db.
# DATABASE_URL=postgres://user:password@postgres.example.com:5432/skill_library

# Optional API keys for protected routes (CLI/MCP auth).
# Format: token:role:actor-id,token:role:actor-id
SKILL_LIBRARY_API_KEYS=change-me-maintainer:maintainer:maintainer-1,change-me-user:user:user-1

# ── Better Auth SSO (Microsoft Entra ID) ──
# Required for browser SSO. Generate a random secret for signing sessions.
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here
# The public URL of the registry (used for OAuth callback URLs).
BETTER_AUTH_URL=http://localhost:3000

# Microsoft Entra ID (Azure AD) App Registration credentials.
# Create an App Registration in Azure Portal → Azure Active Directory → App Registrations.
# Set the redirect URI to: ${BETTER_AUTH_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=your-azure-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
# Use your organization's tenant ID, or "common" for multi-tenant.
MICROSOFT_TENANT_ID=your-azure-tenant-id
